{
  "name": "pi-things",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extensions: unified web tools",
  "license": "MIT",
  "keywords": ["pi-package"],
  "bin": {
    "pi-snapshot": "./extensions/pi-safety/pi-snapshot.ts"
  },
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test:pi-safety": "bun test ./extensions/pi-safety/*.integration.ts && bun test extensions/pi-safety/*.test.ts",
    "typecheck:web-search": "bunx tsc -p extensions/web-search/tsconfig.json",
    "typecheck:web-fetch": "bunx tsc -p extensions/web-fetch/tsconfig.json",
    "typecheck:task-tools": "bunx tsc -p extensions/task-tools/tsconfig.json",
    "typecheck:subagent-tools": "bunx tsc -p extensions/subagent-tools/tsconfig.json",
    "typecheck:diff-review": "bunx tsc -p extensions/diff-review/tsconfig.json",
    "typecheck:pi-safety": "bunx tsc -p extensions/pi-safety/tsconfig.json",
    "typecheck:single-extensions": "bunx tsc -p extensions/tsconfig.json",
    "typecheck": "bun run typecheck:web-search && bun run typecheck:web-fetch && bun run typecheck:task-tools && bun run typecheck:subagent-tools && bun run typecheck:diff-review && bun run typecheck:pi-safety && bun run typecheck:single-extensions"
  },
  "pi": {
    "extensions": [
      "./extensions/web-search/index.ts",
      "./extensions/web-fetch/index.ts",
      "./extensions/task-tools/index.ts",
      "./extensions/subagent-tools/index.ts",
      "./extensions/diff-review/src/index.ts",
      "./extensions/split-fork.ts",
      "./extensions/goal.ts",
      "./extensions/comment.ts",
      "./extensions/pi-safety/index.ts"
    ],
    "skills": ["./skills", "./extensions/web-tools/skills"]
  },
  "dependencies": {
    "defuddle": "^0.15.0",
    "diff": "8.0.4",
    "glimpseui": "^0.8.0",
    "glob-to-regexp": "0.4.1",
    "ignore": "^7.0.5",
    "just-bash": "^2.14.2",
    "linkedom": "^0.18.12",
    "minimatch": "10.2.5",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@earendil-works/pi-agent-core": "0.80.5",
    "@earendil-works/pi-ai": "0.80.5",
    "@earendil-works/pi-coding-agent": "0.80.5",
    "@earendil-works/pi-tui": "0.80.5",
    "@types/bun": "1.3.13",
    "@types/glob-to-regexp": "0.4.4",
    "@types/node": "^24.4.0",
    "typebox": "^1.0.55",
    "typescript": "^6.0.0-dev.20260416"
  }
}
