{
  "name": "pi-things",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extensions: unified web tools",
  "license": "MIT",
  "keywords": ["pi-package"],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test:shell-leash": "bun test extensions/shell-leash/*.test.ts",
    "test:secret-guard": "bun test extensions/secret-guard/*.test.ts",
    "typecheck:web-search": "bunx tsc -p extensions/web-search/tsconfig.json",
    "typecheck:web-fetch": "bunx tsc -p extensions/web-fetch/tsconfig.json",
    "typecheck:task-tools": "bunx tsc -p extensions/task-tools/tsconfig.json",
    "typecheck:subagent-tools": "bunx tsc -p extensions/subagent-tools/tsconfig.json",
    "typecheck:shell-leash": "tsc -p extensions/shell-leash/tsconfig.json",
    "typecheck:secret-guard": "bunx tsc -p extensions/secret-guard/tsconfig.json",
    "typecheck": "bun run typecheck:web-search && bun run typecheck:web-fetch && bun run typecheck:task-tools && bun run typecheck:subagent-tools && bun run typecheck:shell-leash && bun run typecheck:secret-guard"
  },
  "pi": {
    "extensions": [
      "./extensions/web-search/index.ts",
      "./extensions/web-fetch/index.ts",
      "./extensions/task-tools/index.ts",
      "./extensions/subagent-tools/index.ts",
      "./extensions/split-fork.ts",
      "./extensions/shell-leash/index.ts",
      "./extensions/secret-guard/index.ts"
    ],
    "skills": ["./extensions/web-tools/skills"]
  },
  "dependencies": {
    "defuddle": "^0.15.0",
    "ignore": "^7.0.5",
    "just-bash": "^2.14.2",
    "linkedom": "^0.18.12",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@mariozechner/pi-tui": "^0.73.0",
    "@types/node": "^24.4.0",
    "typebox": "^1.0.55",
    "typescript": "^6.0.0-dev.20260416"
  }
}
