{
  "name": "pi-things",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extensions: unified web tools",
  "license": "MIT",
  "keywords": ["pi-package"],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test:shell-leash": "bun test extensions/shell-leash/*.test.ts",
    "typecheck:shell-leash": "tsc -p extensions/shell-leash/tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./extensions/web-tools/index.ts",
      "./extensions/task-tools/index.ts",
      "./extensions/subagent-tools/index.ts",
      "./extensions/split-fork.ts",
      "./extensions/shell-leash/index.ts"
    ],
    "skills": ["./extensions/web-tools/skills"],
    "prompts": ["./extensions/subagent-tools/prompts"]
  },
  "dependencies": {
    "defuddle": "^0.15.0",
    "just-bash": "^2.14.2",
    "linkedom": "^0.18.12",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@mariozechner/pi-tui": "^0.72.1",
    "@types/node": "^24.4.0",
    "typebox": "^1.0.55",
    "typescript": "^6.0.0-dev.20260416"
  }
}
